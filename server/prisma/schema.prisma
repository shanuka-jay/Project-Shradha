// Prisma Schema for Saddha Temple Map
// Database: MongoDB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url   = env("DATABASE_URL")
}

model Temple {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  state     String
  address   String?
  history   String?
  images    String[]
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName  String
  lastName   String
  email      String
  templeName String?
  purpose    String?
  message    String
  createdAt  DateTime @default(now())
}
