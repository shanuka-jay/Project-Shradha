generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Temple {
  id             String   @id @default(cuid())
  name           String
  state          String
  address        String?
  chiefMonk      String?
  phone          String?
  email          String?
  overview       String?
  history        String?
  mainImage      String?
  chiefMonkImage String?
  galleryImages  String   @default("[]")
  images         String   @default("[]")
  services       String   @default("[]")
  lat            Float?
  lng            Float?
  status         String   @default("published")
  mapVisible     Boolean  @default(true)
  regionTag      String?
  monks          Monk[]
  events         Event[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Monk {
  id             String   @id @default(cuid())
  legalName      String
  displayName    String?
  titles         String?
  role           String?
  dateOfBirth    String?
  ordinationDate String?
  nationality    String?
  residence      String?
  languages      String   @default("[]")
  biography      String?
  quote          String?
  contactInfo    String?
  email          String?
  templePhone    String?
  address        String?
  appointment    String?
  profilePhoto   String?
  socialLinks    String?
  linkedTempleId String?
  temple         Temple?  @relation(fields: [linkedTempleId], references: [id])
  status         String   @default("published")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Event {
  id               String    @id @default(cuid())
  title            String
  dateTime         DateTime
  endDateTime      DateTime?
  eventType        String
  description      String?
  linkedTempleId   String?
  temple           Temple?   @relation(fields: [linkedTempleId], references: [id])
  recurring        Boolean   @default(false)
  recurringPattern String?
  status           String    @default("published")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Contact {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String
  templeName String?
  purpose    String?
  message    String
  read       Boolean  @default(false)
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Admin {
  id                       String    @id @default(cuid())
  name                     String
  email                    String    @unique
  passwordHash             String
  passwordResetTokenHash   String?
  passwordResetExpiresAt   DateTime?
  passwordResetRequestedAt DateTime?
  role                     String    @default("editor")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
